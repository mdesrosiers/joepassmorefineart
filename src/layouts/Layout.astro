---
import "~/styles/global.css";
import Header from "~/components/Header.astro";
import Footer from "~/components/Footer.astro";
import SeoHead from "~/components/SeoHead.astro";
import { themeSetterScript } from "../../scripts/csp-script.mjs";

type Props = {
  title: string;
  description: string;
  path: string;
  image?: { src: string; width: number; height: number };
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
};

const { title, description, path, image, jsonLd } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline set:html={themeSetterScript} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <meta name="theme-color" content="#FAF7F2" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#121212" media="(prefers-color-scheme: dark)" />

    <SeoHead title={title} description={description} path={path} image={image} jsonLd={jsonLd} />

    <slot name="head-extra" />
  </head>
  <body class="min-h-dvh">
    <Header />
    <main class="mx-auto max-w-[1280px] px-4 py-8">
      <slot />
    </main>
    <Footer />
  </body>
</html>
