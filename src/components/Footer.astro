---
import { site } from "~/data/site";
---

<footer class="mt-16 border-t border-border bg-surface">
  <div
    class="mx-auto flex max-w-[1280px] flex-col items-center gap-4 px-4 py-8 text-sm text-text-muted"
  >
    <ul class="flex gap-4" aria-label="Social links">
      <li>
        <a
          href={site.social.facebook}
          rel="noopener noreferrer"
          target="_blank"
          aria-label="Facebook"
        >
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M22 12a10 10 0 1 0-11.6 9.9V14.9H7.9V12h2.5V9.8c0-2.5 1.5-3.9 3.8-3.9 1.1 0 2.2.2 2.2.2v2.5h-1.3c-1.2 0-1.6.8-1.6 1.6V12h2.8l-.5 2.9h-2.3v7A10 10 0 0 0 22 12z"
            ></path>
          </svg>
        </a>
      </li>
      <li>
        <a
          href={site.social.instagram}
          rel="noopener noreferrer"
          target="_blank"
          aria-label="Instagram"
        >
          <svg
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
          </svg>
        </a>
      </li>
      <li>
        <a href={site.social.etsy} rel="noopener noreferrer" target="_blank" aria-label="Etsy">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path
              d="M9 4h11v3.5h-2.5c-.5-1.7-1.3-2-3.5-2H10v6h3c1.5 0 2-.3 2.3-1.5h2v6h-2c-.3-1.2-.8-1.5-2.3-1.5h-3v4.7c0 1 .3 1.3 1.3 1.3H14c2.3 0 3.4-.5 4.5-2.7h2L19.5 22H7.5v-2c1.3-.2 1.5-.5 1.5-2V8c0-1.5-.2-1.8-1.5-2V4z"
            ></path>
          </svg>
        </a>
      </li>
    </ul>
    <p>
      &copy; {site.copyrightYear}
      {site.title}. All rights reserved.
    </p>
  </div>
</footer>
