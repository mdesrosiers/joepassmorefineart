---
import { Image } from "astro:assets";
import type { Painting } from "~/data/paintings";

type Props = {
  painting: Painting;
  image: ImageMetadata;
  prev: Painting | undefined;
  next: Painting | undefined;
};

const { painting, image, prev, next } = Astro.props;
---

<article class="mx-auto max-w-5xl">
  <Image
    src={image}
    alt={painting.alt}
    widths={[640, 960, 1280, 1600]}
    sizes="(min-width: 1280px) 1280px, 100vw"
    loading="eager"
    fetchpriority="high"
    class="w-full bg-surface"
  />

  {
    (painting.title || painting.description) && (
      <div class="mt-6">
        {painting.title && <h1 class="font-serif text-3xl">{painting.title}</h1>}
        {painting.medium && (
          <p class="mt-1 text-sm text-text-muted">
            {painting.medium}
            {painting.year ? ` · ${painting.year}` : ""}
          </p>
        )}
        {painting.description && <p class="mt-4 text-text">{painting.description}</p>}
        {painting.etsyUrl && (
          <a
            href={painting.etsyUrl}
            rel="noopener noreferrer"
            target="_blank"
            class="mt-4 inline-block"
          >
            Buy a print on Etsy
          </a>
        )}
      </div>
    )
  }

  <nav aria-label="Painting navigation" class="mt-8 flex items-center justify-between text-sm">
    {prev ? <a href={`/paintings/${prev.slug}`}>← {prev.title ?? prev.alt}</a> : <span />}
    <a href="/" class="text-text-muted">Back to gallery</a>
    {next ? <a href={`/paintings/${next.slug}`}>{next.title ?? next.alt} →</a> : <span />}
  </nav>
</article>
