    <h1 class="font-serif text-4xl">Not Found</h1>
    <p class="mt-4 text-[var(--color-text-muted)]">This page doesn&rsquo;t exist.</p>
    <p class="mt-6">
      <a href="/">Back to gallery</a>
    </p>
  </section>
</Layout>
